# Environment Variables for RESEND and RECAPTCHA

# 1. Resend (Email Provider)
# Get your API key from https://resend.com
RESEND_API_KEY=re_123456789

# The email address that will receive the contact form submissions
CONTACT_DESTINATION_EMAIL=your-email@example.com

# 2. Google reCAPTCHA (v2)
# Get your keys from https://www.google.com/recaptcha/admin
# Important: Use "reCAPTCHA v2" (Check box)

# For Frontend (prefixed with VITE_ to be available in the browser)
VITE_RECAPTCHA_SITE_KEY=your-site-key

# For Backend (Serverless Function)
RECAPTCHA_SECRET_KEY=your-secret-key
